# Copy this file to .env and fill in real secrets before running.

# Database
# `DATABASE_URL` is for local non-docker runs.
DATABASE_URL=postgresql://admin:admin123@localhost:5432/estatepro
# `DATABASE_URL_DOCKER` is used by docker-compose backend service.
DATABASE_URL_DOCKER=postgresql://admin:admin123@postgres:5432/estatepro
POSTGRES_USER=admin
POSTGRES_PASSWORD=replace-with-db-password
POSTGRES_DB=estatepro
POSTGRES_HOST_PORT=5433

# JWT
SECRET_KEY=replace-with-a-strong-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ChromaDB
CHROMA_PATH=./chroma_store
CHROMA_PATH_DOCKER=/app/chroma_store
CHROMA_COLLECTION_NAME=real_estate_docs

# Groq
GROQ_API_KEY=replace-with-your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# App
BACKEND_URL=http://localhost:8080
BACKEND_URL_DOCKER=http://backend:8080

# LangSmith (optional)
LANGSMITH_TRACING_V2=true
LANGSMITH_API_KEY=replace-with-your-langsmith-api-key
LANGSMITH_PROJECT=estate-nexa
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
